# Copy to .env and adjust. Loaded automatically at import via python-dotenv.

# Whisper model configuration
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto

# Output directory for downloads and audio chunks (blank = system temp)
OUTPUT_DIR=./output

# Path to Netscape-format cookies file for age-gated / authenticated videos.
# Export from browser with a cookies.txt extension. Blank = none.
COOKIES_FILE=
